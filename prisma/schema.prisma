generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  nickname        String           @unique
  passwordHash    String
  coins           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  catches         Catch[]
  furnitureItems  FurnitureItem[]
  voxelObjects    VoxelObject[]
  voxelPlacements VoxelPlacement[]

  @@map("users")
}

model VoxelObject {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String           @db.VarChar(50)
  price      Int
  voxels     Json             // [{x,y,z,color}, ...]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  placements VoxelPlacement[]

  @@index([userId])
  @@map("voxel_objects")
}

model VoxelPlacement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voxelObjectId String
  voxelObject   VoxelObject @relation(fields: [voxelObjectId], references: [id], onDelete: Cascade)
  posX          Float       @default(0)
  posZ          Float       @default(0)
  rotY          Float       @default(0)
  placedAt      DateTime    @default(now())

  @@index([userId])
  @@map("voxel_placements")
}

model FurnitureItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  catId       String    // sofa, plant, lamp, table, tv, rug, clock, art
  placed      Boolean   @default(false)
  posX        Float?
  posZ        Float?
  rotY        Float?
  purchasedAt DateTime  @default(now())
  placedAt    DateTime?

  @@index([userId])
  @@index([userId, placed])
  @@map("furniture_items")
}

/// 일반·희귀 아이템의 AI 픽셀아트 공유 캐시 (이름이 키)
model SharedPixelArt {
  name      String   @id @db.VarChar(100)
  imageData String   @db.Text         // data:image/png;base64,...
  rarity    String   @db.VarChar(20)
  type      String   @db.VarChar(20)
  createdAt DateTime @default(now())

  @@map("shared_pixel_arts")
}

model Catch {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemName  String
  itemEmoji String    @default("❓")
  itemType  String    // fish, artifact, crystal, creature, debris, cosmic, scrap
  rarity    String    // common, rare, epic, legendary
  size      Float?
  coinValue Int
  /// 픽셀 스프라이트 { w, h, palette: string[], cells: number[] } — 클라이언트가 표시용으로 저장
  pixelArt  Json?
  sold      Boolean   @default(false)
  soldAt    DateTime?
  caughtAt  DateTime  @default(now())

  @@index([userId])
  @@index([userId, caughtAt])
  @@index([userId, sold])
  @@map("catches")
}
