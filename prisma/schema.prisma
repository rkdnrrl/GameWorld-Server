generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  nickname            String             @unique
  passwordHash        String?  // Supabase Auth 사용 시 null (Supabase가 비밀번호 관리)
  coins               Int                @default(0)
  /// 운영 콘솔 접근 (또는 환경변수 OPERATOR_EMAILS 목록과 병행)
  isOperator          Boolean            @default(false)
  /// 낚시 등으로 포획해 서버에 저장한 횟수 누적(재료 소모로 Catch 행이 삭제되어도 감소하지 않음)
  lifetimeCatchCount  Int                @default(0)
  /// 대장간 숙련도 수치 (float, 제련 성공/실패마다 소량 누적)
  smithingProficiency Float              @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  catches             Catch[]
  craftedEquipment CraftedEquipment[]
  furnitureItems   FurnitureItem[]
  voxelObjects     VoxelObject[]
  voxelPlacements  VoxelPlacement[]
  smeltStock            SmeltStock[]
  alchemyElementStocks  AlchemyElementStock[]
  dungeonSave           DungeonSave?
  userRecord            UserRecord?
  activityLogs          ActivityLog[]
  enhancementStocks     EnhancementStock[]
  modules               Module[]
  donations             Donation[]

  @@map("users")
}

model VoxelObject {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String           @db.VarChar(50)
  price      Int
  voxels     Json             // [{x,y,z,color}, ...]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  placements VoxelPlacement[]

  @@index([userId])
  @@map("voxel_objects")
}

model VoxelPlacement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voxelObjectId String
  voxelObject   VoxelObject @relation(fields: [voxelObjectId], references: [id], onDelete: Cascade)
  posX          Float       @default(0)
  posZ          Float       @default(0)
  rotY          Float       @default(0)
  placedAt      DateTime    @default(now())

  @@index([userId])
  @@map("voxel_placements")
}

model FurnitureItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  catId       String    // sofa, plant, lamp, table, tv, rug, clock, art
  placed      Boolean   @default(false)
  posX        Float?
  posZ        Float?
  rotY        Float?
  purchasedAt DateTime  @default(now())
  placedAt    DateTime?

  @@index([userId])
  @@index([userId, placed])
  @@map("furniture_items")
}

/// 일반·희귀 아이템의 AI 픽셀아트 공유 캐시 (이름이 키)
model SharedPixelArt {
  name      String   @id @db.VarChar(100)
  imageData String   @db.Text         // data:image/png;base64,...
  rarity    String   @db.VarChar(20)
  type      String   @db.VarChar(20)
  createdAt DateTime @default(now())

  @@map("shared_pixel_arts")
}

model Catch {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemName  String
  itemEmoji String    @default("❓")
  itemType  String    // fish, artifact, crystal, creature, debris, cosmic, scrap
  rarity    String    // common, epic, legendary (신규는 rare 없음 — 레거시 행만 rare 가능)
  size      Float?
  coinValue Int
  /// 픽셀 스프라이트 { w, h, palette: string[], cells: number[] } — 클라이언트가 표시용으로 저장
  pixelArt  Json?
  sold      Boolean   @default(false)
  soldAt    DateTime?
  caughtAt  DateTime  @default(now())

  @@index([userId])
  @@index([userId, caughtAt])
  @@index([userId, sold])
  @@map("catches")
}

/// 대장간(Singleplay-Game5) 제작 장비 — 재료 Catch 삭제 후 생성
model CraftedEquipment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeId       String   @db.VarChar(64)
  name           String   @db.VarChar(120)
  itemEmoji      String   @default("⚔️") @db.VarChar(16)
  tier           String   @default("common") @db.VarChar(20)
  desc           String?  @db.VarChar(400)
  /// { attackBonus, defenseBonus, speedBonus, durabilityMax, durability? }
  stats          Json
  /// 제작에 소모된 재료 [{ kind: "catch"|"equipment", id }] (레거시: catch id 문자열 배열)
  sourceCatchIds Json
  /// 절차적 {cells,palette,...} 또는 PixelLab { imageDataUrl, source }
  pixelArt       Json?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("crafted_equipment")
}

/// 대장간 용광로 녹인 산출물 (유리액·철괴 등) — 유저별 집계
model SmeltStock {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @db.VarChar(32)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([userId, productId])
  @@index([userId])
  @@map("smelt_stock")
}

/// 던전 탐험 (Singleplay-Game7) 세이브 — 유저당 1개
model DungeonSave {
  userId  String   @id
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data    Json
  savedAt DateTime @updatedAt

  @@map("dungeon_saves")
}

/// 공지사항 / 패치노트
model Announcement {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(120)
  body      String   @db.Text
  /// notice | patch
  kind      String   @default("notice") @db.VarChar(20)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

/// 게임별 개인 최고 기록
model UserRecord {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dungeonMaxFloor Int      @default(0)
  dungeonMaxKills Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@map("user_records")
}

/// 활동 로그 — 낚시·용광로·제련 이벤트 기록
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname  String   @db.VarChar(64)
  action    String   @db.VarChar(32)   // fish_catch | smelt_melt | forge_craft
  detail    Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

/// 던전에서 획득한 강화 아이템 재고 (유저별·아이템 타입별 집계)
model EnhancementStock {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// stone_common | stone_rare | crystal_magic | shard_legend
  itemType  String   @db.VarChar(32)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([userId, itemType])
  @@index([userId])
  @@map("enhancement_stock")
}

/// 장비 개조 모듈 (대장간에서 제작, 장비 슬롯에 장착)
model Module {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String   @db.VarChar(80)
  moduleType    String   @db.VarChar(32)
  tier          String   @default("common") @db.VarChar(20)
  keywords      Json
  stats         Json
  durability    Int      @default(25)
  durabilityMax Int      @default(25)
  equippedTo    String?  @db.VarChar(50)
  equippedSlot  String?  @db.VarChar(32)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([equippedTo])
  @@map("modules")
}

/// 토스페이먼츠 후원 내역
model Donation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId    String   @unique @db.VarChar(64)
  paymentKey String   @db.VarChar(200)
  amount     Int      // 결제 금액 (원)
  coins      Int      // 지급 코인
  status     String   @default("done") @db.VarChar(20)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("donations")
}

/// 연금술 분해로 얻은 주기율표 원소 (유저별 집계)
model AlchemyElementStock {
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String   @db.VarChar(8)
  nameKo       String?  @db.VarChar(40)
  atomicNumber Int?
  count        Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@id([userId, symbol])
  @@index([userId])
  @@map("alchemy_element_stock")
}
