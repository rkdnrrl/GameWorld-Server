# Server
NODE_ENV=development
PORT=3000

# PostgreSQL connection string
# Example (local):  postgresql://gameworld:password@localhost:5432/gameworld
# Example (Lightsail same host): postgresql://gameworld:password@127.0.0.1:5432/gameworld
DATABASE_URL=postgresql://user:password@localhost:5432/gameworld

# CORS allowed origins (comma-separated). Use * during early dev only.
CORS_ORIGIN=*

# JWT 토큰 서명에 사용. 운영에서는 반드시 강한 랜덤 문자열로 변경.
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Gemini (Google AI Studio API 키) — 동적 제련(모루) 시 장비 이름·스탯 JSON 생성에 필요.
# 키가 없거나 잘못되면 서버가 클라이언트/휴리스틱 이름으로 폴백합니다.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 또는 GOOGLE_AI_API_KEY=...
# 선택. 기본: gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash-lite
