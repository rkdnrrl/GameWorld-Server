# Server
NODE_ENV=development
PORT=3000

# PostgreSQL connection string
# Example (local):  postgresql://gameworld:password@localhost:5432/gameworld
# Example (Lightsail same host): postgresql://gameworld:password@127.0.0.1:5432/gameworld
DATABASE_URL=postgresql://user:password@localhost:5432/gameworld

# CORS allowed origins (comma-separated). Use * during early dev only.
CORS_ORIGIN=*

# ── 인증 방식: 둘 중 하나만 설정 ────────────────────────────
# A) Supabase Auth 사용 시 (권장)
#    Supabase 대시보드 → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# B) 자체 JWT 사용 시 (레거시)
#    SUPABASE_JWT_SECRET 가 없을 때만 사용됨
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# 싱글 게임 URL — `/api/games` 목록에 노출 (미설정 시 games.js 기본 호스트 사용)
# SPACE_FISHING_URL=
# SINGLEPLAY_GAME5_URL=   # 대장간 (레포 Singleplay-Game5)
# BLACKSMITH_URL=         # 대장간 별칭
# SINGLEPLAY_GAME6_URL= # 연금술 (레포 Singleplay-Game6)
# ALCHEMY_URL=            # 연금술 별칭

# Gemini (Google AI Studio API 키) — 동적 제련(모루) 장비 이름·스탯, 낚시 스크랩 작명 등에 사용. (연금술 분해는 규칙 기반)
# 키가 없거나 잘못되면 제련은 휴리스틱 폴백, 연금술 분해는 503입니다.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 또는 GOOGLE_AI_API_KEY=...
# 선택. 기본: gemini-2.5-flash-lite (프로젝트에서 404/400이면 gemini-2.0-flash 등으로 변경)
# GEMINI_MODEL=gemini-2.0-flash
# 주 모델 실패 시 제련 이름용으로 한 번 더 호출 (기본 gemini-2.0-flash)
# GEMINI_MODEL_FALLBACK=gemini-2.0-flash
